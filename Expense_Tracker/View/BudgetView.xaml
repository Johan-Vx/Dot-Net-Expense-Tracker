<UserControl x:Class="Expense_Tracker.View.BudgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Expense_Tracker.View"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Quản lý Ngân sách" FontSize="28" FontWeight="Bold" Foreground="{StaticResource ColorTextPrimary}"/>
            <TextBlock Text="Thiết lập và theo dõi ngân sách chi tiêu theo tháng" Foreground="{StaticResource ColorTextMuted}" FontSize="13" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Month/Year Selector -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,15">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                    <TextBlock Text="📅 Tháng:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}" Width="70"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                    <TextBlock Text="Năm:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SelectedYear, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                </StackPanel>

                <Button Content="📥 Tải Ngân sách" Command="{Binding LoadBudgetCommand}" 
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,5"/>
                <Button Content="➕ Thêm dòng" Command="{Binding AddLineCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,5"/>
                <Button Content="💾 Lưu" Command="{Binding SaveBudgetCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,5"/>
            </WrapPanel>
        </Border>

        <!-- Budget DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <DataGrid ItemsSource="{Binding BudgetLines}"
                      Style="{StaticResource DataGridDarkStyle}"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      AutoGenerateColumns="False" SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <!-- Category ComboBox -->
                    <DataGridComboBoxColumn Header="Danh mục Chi"
                        ItemsSource="{Binding DataContext.DanhMucs,
                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                        DisplayMemberPath="TenDM"
                        SelectedValuePath="MaDM"
                        SelectedValueBinding="{Binding MaDM}"
                        Width="180"/>

                    <!-- Planned Amount (editable) -->
                    <DataGridTextColumn Header="Kế hoạch (đ)"
                                       Binding="{Binding SoTienKeHoach, StringFormat={}{0:N0}}"
                                       Width="140"/>

                    <!-- Actual Amount (read-only) -->
                    <DataGridTextColumn Header="Thực tế (đ)"
                                       Binding="{Binding ThucTe, StringFormat={}{0:N0}}"
                                       IsReadOnly="True"
                                       Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Progress Bar -->
                    <DataGridTemplateColumn Header="Tiến độ" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="5,2">
                                    <ProgressBar Value="{Binding TiLe, Mode=OneWay}" 
                                                 Maximum="100" Height="20" 
                                                 Background="{StaticResource ColorSurfaceHover}">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar">
                                                <Setter Property="Foreground" Value="{StaticResource ColorSuccess}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TiLe, Converter={x:Static local:BudgetView.OverBudgetConverter}}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource ColorDanger}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>
                                    <TextBlock Text="{Binding TiLe, StringFormat={}{0:F1}%}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11" FontWeight="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Delete button -->
                    <DataGridTemplateColumn Header="" Width="36">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕"
                                        Foreground="{StaticResource ColorDanger}"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="13" Padding="2"
                                        Command="{Binding DataContext.DeleteLineCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Summary Footer -->
        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="TỔNG KẾ HOẠCH" Foreground="{StaticResource ColorTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalPlanned, StringFormat={}{0:N0} VNĐ}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource ColorAccent}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="TỔNG THỰC TẾ" Foreground="{StaticResource ColorTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalActual, StringFormat={}{0:N0} VNĐ}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource ColorDanger}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="CÒN LẠI" Foreground="{StaticResource ColorTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource ColorSuccess}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:N0} VNĐ">
                                <Binding Path="TotalPlanned"/>
                                <Binding Path="TotalActual"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
