<UserControl x:Class="Expense_Tracker.View.PhieuThuChiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Expense_Tracker.View"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="900">

    <!-- Keyboard shortcuts: Ctrl+N Thêm, Ctrl+S Lưu, Del Xóa phiếu -->
    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="Delete"             Command="{Binding DeleteCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Lập Phiếu Thu / Chi"
                   FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource ColorTextPrimary}"
                   Margin="0,0,0,20" Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Master column fixed 280px, detail flexible -->
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ MASTER LIST ══════════════════════════════════════ -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="➕ Thêm Mới (Ctrl+N)"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,8,0"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding PhieuThuChis}"
                              SelectedItem="{Binding SelectedPhieu}"
                              Style="{StaticResource DataGridDarkStyle}"
                              IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Số Phiếu"
                                               Binding="{Binding SoPhieu}"
                                               Width="*"/>
                            <DataGridTextColumn Header="Ngày"
                                               Binding="{Binding NgayLap, StringFormat=dd/MM/yy}"
                                               Width="75"/>
                            <DataGridTextColumn Header="Loại"
                                               Binding="{Binding LoaiPhieu}"
                                               Width="45"/>
                            <DataGridTextColumn Header="Tổng"
                                               Binding="{Binding TongTien, StringFormat={}{0:N0}}"
                                               Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- ══ DETAIL VIEW ══════════════════════════════════════ -->
            <Border Grid.Column="1">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedPhieu}" Value="{x:Null}">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="Opacity"   Value="0.5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <DockPanel>

                    <!-- Bottom action bar -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="🗑 Xóa (Del)"
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                Margin="0,0,10,0"/>
                        <Button Content="💾 Lưu (Ctrl+S)"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,12,0"
                                    DataContext="{Binding SelectedPhieu}">

                            <!-- ═══ SECTION A: Thông Tin Chung ═══ -->
                            <GroupBox Margin="0,0,0,14">
                                <GroupBox.Header>
                                    <TextBlock Text="📋 Thông Tin Chung" FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource ColorAccent}"/>
                                </GroupBox.Header>
                                <StackPanel Margin="5,8,5,0">
                                    <!-- Row 1: Ngày Lập + Loại Phiếu -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Ngày Lập" Margin="0,0,0,4"
                                                       Foreground="{StaticResource ColorTextMuted}"/>
                                            <DatePicker SelectedDate="{Binding NgayLap}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Loại Phiếu" Margin="0,0,0,4"
                                                       Foreground="{StaticResource ColorTextMuted}"/>
                                            <!-- LoaiPhieu change → FilteredDanhMucs refresh via ViewModel -->
                                            <ComboBox ItemsSource="{Binding DataContext.LoaiPhieus,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedItem="{Binding LoaiPhieu}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Row 2: Người Nộp/Nhận + Tài Khoản Quỹ -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- NguoiNopNhan — UpdateSourceTrigger để validate real-time -->
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Foreground="{StaticResource ColorTextMuted}" Margin="0,0,0,4">
                                                <Run Text="Người Nộp / Nhận"/>
                                                <Run Text=" *" Foreground="{StaticResource ColorDanger}"/>
                                            </TextBlock>
                                            <TextBox Text="{Binding NguoiNopNhan,
                                                            UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding NguoiNopNhan}" Value="">
                                                                <Setter Property="BorderBrush" Value="{StaticResource ColorDanger}"/>
                                                                <Setter Property="ToolTip"     Value="Trường bắt buộc nhập"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>

                                        <!-- MaQuy — border đỏ khi chưa chọn -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Foreground="{StaticResource ColorTextMuted}" Margin="0,0,0,4">
                                                <Run Text="Tài Khoản Quỹ"/>
                                                <Run Text=" *" Foreground="{StaticResource ColorDanger}"/>
                                            </TextBlock>
                                            <ComboBox ItemsSource="{Binding DataContext.TaiKhoanQuys,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedItem="{Binding TaiKhoanQuy}"
                                                      SelectedValue="{Binding MaQuy}"
                                                      SelectedValuePath="MaQuy"
                                                      DisplayMemberPath="TenQuy">
                                                <ComboBox.Style>
                                                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MaQuy}" Value="{x:Null}">
                                                                <Setter Property="BorderBrush" Value="{StaticResource ColorDanger}"/>
                                                                <Setter Property="ToolTip"     Value="Vui lòng chọn tài khoản quỹ"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBox.Style>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Lý Do -->
                                    <TextBlock Text="Lý Do" Margin="0,0,0,4"
                                               Foreground="{StaticResource ColorTextMuted}"/>
                                    <TextBox Text="{Binding LyDoChung}"
                                             Height="55" TextWrapping="Wrap"
                                             AcceptsReturn="True" Margin="0,0,0,0"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- ═══ SECTION B: Chi Tiết Phiếu ═══ -->
                            <GroupBox Margin="0,0,0,0">
                                <GroupBox.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="📝 Chi Tiết Phiếu" FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource ColorAccent}" VerticalAlignment="Center"/>

                                        <Button Grid.Column="1"
                                                Content="➕ Thêm Dòng"
                                                Command="{Binding DataContext.AddChiTietCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="8,4"/>
                                    </Grid>
                                </GroupBox.Header>

                                <StackPanel Margin="5,8,5,0">
                                    <!-- DataGrid chi tiết — inline editable -->
                                    <DataGrid ItemsSource="{Binding DataContext.ChiTietPhieus,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Style="{StaticResource DataGridDarkStyle}"
                                              Height="180"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              AutoGenerateColumns="False"
                                              SelectionUnit="FullRow"
                                              CellEditEnding="ChiTietGrid_CellEditEnding"
                                              x:Name="ChiTietGrid">
                                        <DataGrid.Columns>

                                            <!-- FilteredDanhMucs theo LoaiPhieu -->
                                            <DataGridComboBoxColumn Header="Danh Mục *"
                                                ItemsSource="{Binding DataContext.FilteredDanhMucs,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                DisplayMemberPath="TenDM"
                                                SelectedValuePath="MaDM"
                                                SelectedValueBinding="{Binding MaDM}"
                                                Width="160"/>

                                            <DataGridTextColumn Header="Ghi Chú"
                                                               Binding="{Binding GhiChu}"
                                                               Width="*"/>

                                            <!-- SoTien — editable, format N0 -->
                                            <DataGridTextColumn Header="Số Tiền"
                                                               Binding="{Binding SoTien, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}"
                                                               Width="110"/>

                                            <!-- Nút xóa dòng -->
                                            <DataGridTemplateColumn Header="" Width="36">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="✕"
                                                                Foreground="{StaticResource ColorDanger}"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                FontSize="13"
                                                                Padding="2"
                                                                Command="{Binding DataContext.DeleteChiTietCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- Real-time TongTien display -->
                                    <TextBlock HorizontalAlignment="Right"
                                               Margin="0,8,0,0"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource ColorDanger}">
                                        <Run Text="Tổng: "/>
                                        <Run Text="{Binding TongTien, StringFormat={}{0:N0} đ}"/>
                                    </TextBlock>
                                </StackPanel>
                            </GroupBox>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
