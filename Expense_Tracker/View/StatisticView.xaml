<UserControl x:Class="Expense_Tracker.View.StatisticView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Expense_Tracker.View"
             xmlns:viewmodel="clr-namespace:Expense_Tracker.ViewModel"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="1400" d:DesignWidth="1000">

    <UserControl.DataContext>
        <viewmodel:StatisticViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Row 0: Title -->
                <RowDefinition Height="Auto"/>  <!-- Row 1: Summary Cards -->
                <RowDefinition Height="Auto"/>  <!-- Row 2: 6 Charts Grid -->
                <RowDefinition Height="Auto"/>  <!-- Row 3: Recent Transactions -->
            </Grid.RowDefinitions>

            <!-- ── Tiêu đề trang ── -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Thống kê hệ thống" FontSize="28" FontWeight="Bold" Foreground="{StaticResource ColorTextPrimary}"/>
                <TextBlock Text="Phân tích &amp; Thống kê tài chính thời gian thực" Foreground="{StaticResource ColorTextMuted}" FontSize="13" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- ── Summary Cards ── -->
            <Grid Grid.Row="1" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1: Số dư -->
                <Border Grid.Column="0" Margin="0,0,10,0" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="20"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Color="#E2E8F0" Opacity="0.5" ShadowDepth="1"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="TỔNG SỐ DƯ HIỆN TẠI" Foreground="{StaticResource ColorTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding TongSoDu, StringFormat={}{0:N0} VNĐ}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource ColorAccent}"/>
                    </StackPanel>
                </Border>

                <!-- Card 2: Thu tháng này -->
                <Border Grid.Column="1" Margin="10,0,10,0" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="20"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Color="#E2E8F0" Opacity="0.5" ShadowDepth="1"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="THU NHẬP THÁNG NÀY" Foreground="{StaticResource ColorTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding TongThuThangNay, StringFormat={}{0:N0} VNĐ}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource ColorSuccess}"/>
                    </StackPanel>
                </Border>

                <!-- Card 3: Chi tháng này -->
                <Border Grid.Column="2" Margin="10,0,0,0" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="20"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Color="#E2E8F0" Opacity="0.5" ShadowDepth="1"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="CHI TIÊU THÁNG NÀY" Foreground="{StaticResource ColorTextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding TongChiThangNay, StringFormat={}{0:N0} VNĐ}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource ColorDanger}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── 6 Charts UniformGrid ── -->
            <UniformGrid Grid.Row="2" Columns="2" Rows="3" Margin="0,0,0,25">
                
                <!-- 1. Doughnut Chart: Tỷ lệ Giao dịch Thu/Chi -->
                <Border Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="15" Margin="0,0,10,12"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1" MinHeight="280">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Color="#E2E8F0" Opacity="0.5" ShadowDepth="1"/></Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Tỷ lệ Số lượng Phiếu Thu vs Chi" FontWeight="Bold" Foreground="{StaticResource ColorTextPrimary}" FontSize="14" Margin="0,0,0,10"/>
                        <lvc:PieChart Series="{Binding DoughnutSeries}" LegendLocation="Right" InnerRadius="50" Hoverable="True" DataTooltip="{x:Null}" Height="250">
                            <lvc:PieChart.ChartLegend>
                                <lvc:DefaultLegend BulletSize="12" Foreground="{StaticResource ColorTextPrimary}"/>
                            </lvc:PieChart.ChartLegend>
                        </lvc:PieChart>
                    </DockPanel>
                </Border>

                <!-- 2. Pie Chart: Cơ cấu chi tiêu theo Danh mục -->
                <Border Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="15" Margin="10,0,0,12"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1" MinHeight="280">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Color="#E2E8F0" Opacity="0.5" ShadowDepth="1"/></Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Phân bổ Chi tiêu theo Danh mục (6 tháng)" FontWeight="Bold" Foreground="{StaticResource ColorTextPrimary}" FontSize="14" Margin="0,0,0,10"/>
                        <lvc:PieChart Series="{Binding PieSeries}" LegendLocation="Right" Hoverable="True" Height="250">
                            <lvc:PieChart.ChartLegend>
                                <lvc:DefaultLegend BulletSize="12" Foreground="{StaticResource ColorTextPrimary}"/>
                            </lvc:PieChart.ChartLegend>
                        </lvc:PieChart>
                    </DockPanel>
                </Border>

                <!-- 3. Bar Chart: Top 5 danh mục chi tiêu lớn nhất -->
                <Border Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="15" Margin="0,0,10,12"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1" MinHeight="280">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Color="#E2E8F0" Opacity="0.5" ShadowDepth="1"/></Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Top 5 Danh mục chi nhiều nhất" FontWeight="Bold" Foreground="{StaticResource ColorTextPrimary}" FontSize="14" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Series="{Binding BarSeries}" Height="250">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Số tiền (đ)" LabelFormatter="{Binding BarFormatter}" Foreground="{StaticResource ColorTextMuted}"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Labels="{Binding BarLabels}" Foreground="{StaticResource ColorTextMuted}"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </DockPanel>
                </Border>

                <!-- 4. Line Graph: Xu hướng chi tiêu theo thời gian -->
                <Border Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="15" Margin="10,0,0,12"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1" MinHeight="280">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Color="#E2E8F0" Opacity="0.5" ShadowDepth="1"/></Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Xu hướng Chi tiêu 6 tháng qua" FontWeight="Bold" Foreground="{StaticResource ColorTextPrimary}" FontSize="14" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Series="{Binding SingleLineSeries}" Height="250">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Tháng" Labels="{Binding SingleLineLabels}" Foreground="{StaticResource ColorTextMuted}"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Tổng Chi" LabelFormatter="{Binding SingleLineFormatter}" Foreground="{StaticResource ColorTextMuted}"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </DockPanel>
                </Border>

                <!-- 5. Column Chart: So sánh Thu vs Chi -->
                <Border Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="15" Margin="0,0,10,0"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1" MinHeight="280">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Color="#E2E8F0" Opacity="0.5" ShadowDepth="1"/></Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="So sánh Tổng số tiền Thu vs Chi" FontWeight="Bold" Foreground="{StaticResource ColorTextPrimary}" FontSize="14" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Series="{Binding ColumnSeries}" LegendLocation="Top" Height="250">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Tháng" Labels="{Binding ColumnLabels}" Foreground="{StaticResource ColorTextMuted}"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Số tiền" LabelFormatter="{Binding ColumnFormatter}" Foreground="{StaticResource ColorTextMuted}"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </DockPanel>
                </Border>

                <!-- 6. Line Graph (2+ Line Series): Đối chiếu Số phiếu Thu vs Chi -->
                <Border Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="15" Margin="10,0,0,0"
                        BorderBrush="{StaticResource ColorBorder}" BorderThickness="1" MinHeight="280">
                    <Border.Effect><DropShadowEffect BlurRadius="8" Color="#E2E8F0" Opacity="0.5" ShadowDepth="1"/></Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Đối chiếu Số lượng giao dịch Thu vs Chi" FontWeight="Bold" Foreground="{StaticResource ColorTextPrimary}" FontSize="14" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Series="{Binding MultiLineSeries}" LegendLocation="Top" Height="250">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Tháng" Labels="{Binding MultiLineLabels}" Foreground="{StaticResource ColorTextMuted}"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Số lượng giao dịch" LabelFormatter="{Binding MultiLineFormatter}" Foreground="{StaticResource ColorTextMuted}"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </DockPanel>
                </Border>

            </UniformGrid>

            <!-- ── Recent Transactions Table ── -->
            <Border Grid.Row="3" Background="{StaticResource ColorSurface}" CornerRadius="8" Padding="20"
                    BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
                <Border.Effect><DropShadowEffect BlurRadius="8" Color="#E2E8F0" Opacity="0.5" ShadowDepth="1"/></Border.Effect>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Các giao dịch gần đây" FontSize="18" FontWeight="Bold" Foreground="{StaticResource ColorTextPrimary}" Margin="0,0,0,20"/>
                    <DataGrid ItemsSource="{Binding RecentTransactions}" 
                              Style="{StaticResource DataGridDarkStyle}"
                              IsReadOnly="True"
                              RowHeight="40"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding SoPhieu}" Width="110"/>
                            <DataGridTextColumn Header="Ngày Lập" Binding="{Binding NgayLap, StringFormat=dd/MM/yyyy}" Width="120"/>
                            <DataGridTextColumn Header="Loại" Binding="{Binding LoaiPhieu}" Width="80"/>
                            <DataGridTextColumn Header="Số Tiền" Binding="{Binding TongTien, StringFormat={}{0:N0}}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="10,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Người Lập" Binding="{Binding NguoiDung.HoTen}" Width="150"/>
                            <DataGridTextColumn Header="Nội dung" Binding="{Binding LyDoChung}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
