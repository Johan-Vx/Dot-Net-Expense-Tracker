<UserControl x:Class="Expense_Tracker.View.LedgerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Expense_Tracker.View"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Sổ Quỹ Thu Chi" FontSize="28" FontWeight="Bold" Foreground="{StaticResource ColorTextPrimary}" Margin="0,0,0,20" Grid.Row="0"/>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,20">
            <StackPanel>
                <!-- Row 1: Date range + Transaction type + Fund account -->
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                        <TextBlock Text="Từ ngày:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Width="130"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                        <TextBlock Text="Đến ngày:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Width="130"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                        <TextBlock Text="Loại:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding LoaiPhieuOptions}"
                                  SelectedItem="{Binding SelectedLoaiPhieu}"
                                  Width="100"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                        <TextBlock Text="Quỹ:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding TaiKhoanQuys}"
                                  SelectedValue="{Binding SelectedMaQuy}"
                                  SelectedValuePath="MaQuy"
                                  DisplayMemberPath="TenQuy"
                                  Width="140"/>
                    </StackPanel>
                </WrapPanel>

                <!-- Row 2: Category + Search + Amount range + Filter button -->
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                        <TextBlock Text="Danh mục:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding DanhMucs}"
                                  SelectedValue="{Binding SelectedMaDM}"
                                  SelectedValuePath="MaDM"
                                  DisplayMemberPath="TenDM"
                                  Width="150"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                        <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                        <TextBlock Text="Số tiền từ:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding MinAmountText, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                        <TextBlock Text="đến:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding MaxAmountText, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                    </StackPanel>

                    <Button Content="🔍 Lọc" Command="{Binding FilterCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,5"/>
                    <Button Content="↺ Xóa bộ lọc" Command="{Binding ClearFilterCommand}"
                            Background="{StaticResource ColorSurfaceHover}" Foreground="{StaticResource ColorTextSecondary}"
                            BorderThickness="1" BorderBrush="{StaticResource ColorBorder}" Padding="15,8"
                            FontFamily="{StaticResource FontMain}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <DataGrid ItemsSource="{Binding PhieuThuChis}" Style="{StaticResource DataGridDarkStyle}" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding SoPhieu}" Width="100"/>
                    <DataGridTextColumn Header="Ngày Lập" Binding="{Binding NgayLap, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding LoaiPhieu}" Width="100"/>
                    <DataGridTextColumn Header="Số Tiền" Binding="{Binding TongTien, StringFormat={}{0:N0}}" Width="150"/>
                    <DataGridTextColumn Header="Người Nộp/Nhận" Binding="{Binding NguoiNopNhan}" Width="150"/>
                    <DataGridTextColumn Header="Quỹ" Binding="{Binding TaiKhoanQuy.TenQuy}" Width="150"/>
                    <DataGridTextColumn Header="Người Lập" Binding="{Binding NguoiDung.HoTen}" Width="150"/>
                    <DataGridTextColumn Header="Lý Do" Binding="{Binding LyDoChung}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
