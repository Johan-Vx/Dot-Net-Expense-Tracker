<UserControl x:Class="Expense_Tracker.View.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Expense_Tracker.View"
             mc:Ignorable="d" 
                     xmlns:Viewer="clr-namespace:SAPBusinessObjects.WPF.Viewer;assembly=SAPBusinessObjects.WPF.Viewer"
         d:DesignHeight="600" d:DesignWidth="1100">
    <Grid Background="{StaticResource ColorBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Margin="10">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                    <TextBlock Text="📅 Ngày báo cáo:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                    <TextBlock Text="Từ:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding SelectedStartTime, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                    <TextBlock Text="Đến:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding SelectedEndTime, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                    <TextBlock Text="🏦 Chọn quỹ:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding DanhSachQuy}" 
                          SelectedValuePath="MaQuy" 
                          DisplayMemberPath="TenQuy"
                          SelectedValue="{Binding SelectedMaQuy, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                          Width="150"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <Button Content="📑 Tạo báo cáo thu chi" 
                        Command="{Binding GenerateThuChiCommand}" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Margin="0,0,10,0" Height="35"/>
                    <Button Content="📑 Tạo báo cáo sao kê" 
                        Command="{Binding GenerateSaoKeCommand}" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Height="35"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <Border Grid.Row="1" Margin="10,0,10,10" BorderBrush="{StaticResource ColorBorder}" BorderThickness="1">
            <Viewer:CrystalReportsViewer x:Name="MainReport" ShowStatusbar="True" ShowPrintButton="True" ShowExportButton="True"/>
        </Border>
    </Grid>
</UserControl>
