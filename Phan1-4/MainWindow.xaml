<Window x:Class="Phan1_4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:v="clr-namespace:Phan1_4.View"
        xmlns:vm="clr-namespace:Phan1_4.ViewModel"
        
        mc:Ignorable="d"
        Title="Quản lý tài chính" Height="600" Width="1000">

    <Window.Resources>
        <DataTemplate DataType="{x:Type v:DashBoardView}">
            <v:DashBoardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type v:BudgetsView}">
            <v:BudgetsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type v:TransactionsView}">
            <v:TransactionsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type v:AccountsView}">
            <v:AccountsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type v:CategoriesView}">
            <v:CategoriesView />
        </DataTemplate>
    </Window.Resources>

<Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#2C3E50">
            <TextBlock Text="Hmmm" Foreground="White" Margin="20" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Button Content="Tổng quan" Command="{Binding ShowDashboardCommand}" Margin="10" Height="40" Background="#34495E" Foreground="White"/>
            <Button Content="Ngân sách" Command="{Binding ShowBudgetsCommand}" Margin="10" Height="40" Background="#34495E" Foreground="White"/>
            <Button Content="Giao dịch" Command="{Binding ShowTransactionsCommand}" Margin="10" Height="40" Background="#34495E" Foreground="White"/>
            <Button Content="Tài khoản" Command="{Binding ShowAccountsCommand}" Margin="10" Height="40" Background="#34495E" Foreground="White"/>
            <Button Content="Danh mục" Command="{Binding ShowCategoriesCommand}" Margin="10" Height="40" Background="#34495E" Foreground="White"/>
        </StackPanel>
        <ContentControl Grid.Column="1" Content="{Binding CurrentChildView}" />
</Grid>
</Window>