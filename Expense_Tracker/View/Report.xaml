<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Expense_Tracker.View"
             xmlns:Viewer="clr-namespace:SAPBusinessObjects.WPF.Viewer;assembly=SAPBusinessObjects.WPF.Viewer"
             x:Class="Expense_Tracker.View.Report"
             mc:Ignorable="d" 
             xmlns:report="clr-namespace:Expense_Tracker.Report"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- DatePicker + CheckBox -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="📅 Ngày:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                    <DatePicker x:Name="ReportDate"
                                SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="140" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <CheckBox x:Name="ChkAllDate"
                              IsChecked="{Binding IsAllDate, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="Tất cả ngày" VerticalAlignment="Center" Margin="6,0,0,0"
                               Foreground="{StaticResource ColorTextMuted}" FontSize="13"/>
                </StackPanel>

                <!-- ComboBox Tháng -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="Tháng:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                    <ComboBox ItemsSource="{Binding Months}"
                              SelectedItem="{Binding SelectedMonth, Mode=TwoWay}"
                              Width="70" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ComboBox Năm -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="Năm:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                    <ComboBox ItemsSource="{Binding Years}"
                              SelectedItem="{Binding SelectedYear, Mode=TwoWay}"
                              Width="90" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Button Tạo báo cáo -->
                <Button Grid.Column="5"
                        Content="📑 Tạo báo cáo"
                        Command="{Binding GenerateReportCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        FontSize="14"
                        MinWidth="140"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Crystal Reports Viewer (code-behind only, no binding) ── -->
        <Viewer:CrystalReportsViewer Grid.Row="1" x:Name="MainReport"/>
    </Grid>
</UserControl>
