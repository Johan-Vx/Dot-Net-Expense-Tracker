<Window x:Class="Expense_Tracker.View.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Expense_Tracker.View"
        xmlns:vm="clr-namespace:Expense_Tracker.ViewModel"
        xmlns:behavior="clr-namespace:Expense_Tracker.Behavior"
        mc:Ignorable="d"
        Title="Đăng Nhập" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        behavior:WindowBehavior.DialogResult="{Binding DialogResult}">
    <!-- Binding tính năng đóng cửa sổ -->

    <!-- Khởi tạo ViewModel hoàn toàn bằng XAML -->
    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <Border CornerRadius="20" Background="#FFFFFF" BorderThickness="1" BorderBrush="#DCDDE1">
        <!-- Đổ bóng cho toàn bộ cửa sổ (Chuẩn WPF) -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="#BDBDBD" Direction="0" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <!-- Bên trái: Thương hiệu -->
                <ColumnDefinition Width="1*"/>
                <!-- Bên phải: Form đăng nhập -->
            </Grid.ColumnDefinitions>

            <!-- PHẦN BÊN TRÁI: BRANDING & LOGO -->
            <Border Grid.Column="0" CornerRadius="19,0,0,19">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3F51B5" Offset="0"/>
                        <GradientStop Color="#1A237E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Biểu tượng đại diện -->
                    <Border Width="90" Height="90" Background="#FFFFFF" CornerRadius="45" Margin="0,0,0,20">
                        <TextBlock Text="💰" FontSize="45" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="EXPENSE TRACKER" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="#FFFFFF" 
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Quản lý chi tiêu thông minh" 
                               FontSize="14" 
                               Foreground="#C5CAE9" 
                               HorizontalAlignment="Center" 
                               Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

            <!-- PHẦN BÊN PHẢI: FORM ĐĂNG NHẬP -->
            <Grid Background="#FFFFFF" Grid.ColumnSpan="2" Margin="435,10,10,10">
                <!-- Nút X thoát nhanh ở góc trên bên phải -->
                <Button Content="✕" 
                        Command="{Binding CloseCommand}"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Margin="15"
                        Width="30" Height="30"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#BDC3C7"
                        Cursor="Hand"
                        FontSize="18"/>

                <StackPanel Margin="40" VerticalAlignment="Center">
                    <TextBlock Text="ĐĂNG NHẬP" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#3F51B5" 
                               Margin="0,0,0,30"
                               HorizontalAlignment="Left"/>

                    <!-- Tài khoản -->
                    <TextBlock Text="Tên đăng nhập" Foreground="#7F8C8D" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             Height="40" 
                             Margin="0,0,0,20"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#DCDDE1"
                             FontSize="14"/>

                    <!-- Mật khẩu -->
                    <TextBlock Text="Mật khẩu" Foreground="#7F8C8D" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <PasswordBox Name="txtPassword" 
                                 Height="40" 
                                 Margin="0,0,0,10"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="#DCDDE1"
                                 FontSize="14"/>

                    <!-- Thông báo lỗi -->
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="#E74C3C" 
                               FontSize="12" 
                               Height="25"
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>

                    <!-- Nút Đăng nhập -->
                    <Button Content="ĐĂNG NHẬP" 
                            Command="{Binding LoginCommand}" 
                            CommandParameter="{Binding ElementName=txtPassword}" 
                            Height="45" 
                            Background="#3F51B5" 
                            Foreground="White" 
                            FontWeight="Bold"
                            FontSize="14"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,15">
                        <Button.Resources>
                            <!-- Bo góc cho nút bấm -->
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <!-- Nút Thoát (Thực hiện CloseCommand) -->
                    <Button Content="Thoát ứng dụng" 
                            Command="{Binding CloseCommand}" 
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#95A5A6"
                            FontSize="13"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>