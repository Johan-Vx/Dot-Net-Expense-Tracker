<UserControl x:Class="Expense_Tracker.View.DashBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Expense_Tracker.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="#121513">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFB3EE4A" CornerRadius="15" Padding="20" Margin="0,0,0,15"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding MonthlySpentText, FallbackValue='$645.95'}" 
                           FontSize="28" FontWeight="Bold" Foreground="White" 
                           HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding PercentChangeText, FallbackValue='+12% so với tháng trước'}" 
                           FontSize="14" Foreground="#FF4D4D" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#2C3A47" CornerRadius="15" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Total Balance" FontSize="14" Foreground="#A4B0BE" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding TotalBalanceText, FallbackValue='đ 2,759,000'}" 
                               FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <Button Grid.Column="3" Content="👁" Command="{Binding ToggleBalanceVisibilityCommand}" 
                            Background="Transparent" BorderThickness="0" Foreground="#A4B0BE" FontSize="16" Cursor="Hand"/>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="↑" FontSize="18" FontWeight="Bold" Foreground="#2ED573" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Income" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding IncomeText, FallbackValue='đ 555,200'}" 
                               FontSize="16" FontWeight="SemiBold" Foreground="#2ED573" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="↓" FontSize="18" FontWeight="Bold" Foreground="#FF4757" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Expenses" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding ExpensesText, FallbackValue='đ 3,590,800'}" 
                               FontSize="16" FontWeight="SemiBold" Foreground="#FF4757" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <Rectangle Grid.Row="6" Fill="#576574" Height="1" Opacity="0.5"/>

                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="⚖" FontSize="16" Foreground="#1E90FF" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Balance" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding NetBalanceText, FallbackValue='- đ 3,035,600'}" 
                               FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,5,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Giao dịch gần nhất" FontSize="16" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Left"/>
                <Button Content="Xem tất cả" Command="{Binding NavigateToTransactionsCommand}" 
                        Background="Transparent" BorderThickness="0" Foreground="#1E90FF" HorizontalAlignment="Right" Cursor="Hand"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <ItemsControl ItemsSource="{Binding RecentTransactions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10" BorderBrush="#E0E0E0" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15" Background="#FF9F43" HorizontalAlignment="Left">
                                        <TextBlock Text="🍽" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding GhiChu, FallbackValue='Ăn trưa'}" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                                        <TextBlock Text="{Binding TenNguonTien, FallbackValue='Ví tiền mặt'}" FontSize="12" Foreground="#888888"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding SoTienText, FallbackValue='- 30,000 đ'}" 
                                               FontSize="14" FontWeight="Bold" Foreground="#FF4757" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
