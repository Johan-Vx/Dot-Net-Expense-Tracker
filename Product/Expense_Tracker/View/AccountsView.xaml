<UserControl x:Class="Expense_Tracker.View.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Expense_Tracker.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" 
             Background="#121513">
    <Grid>
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,10,0,25">
                <TextBlock Text="Total balance" FontSize="14" Foreground="#8A9A92" Margin="0,0,0,5"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding TotalBalanceText, FallbackValue='đ********'}" 
                               FontSize="28" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="👁" Command="{Binding ToggleTotalBalanceVisibilityCommand}" 
                            Background="Transparent" BorderThickness="0" Foreground="#2ED573" FontSize="20" 
                            Cursor="Hand" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <ItemsControl ItemsSource="{Binding Accounts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1C2420" CornerRadius="12" Padding="15" Margin="0,0,0,12" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" 
                                                  Command="{Binding DataContext.EditAccountCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="15"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" 
                                                Background="{Binding ColorHex, FallbackValue='#4CAF50'}" 
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding IconText, FallbackValue='💳'}" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                       Foreground="White" FontSize="18"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                                            <TextBlock Text="{Binding AccountName, FallbackValue='Wallet'}" 
                                                       FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock Text="{Binding AccountType, FallbackValue='Cash'}" 
                                                       FontSize="13" Foreground="#8A9A92" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="›" FontSize="24" Foreground="#8A9A92" 
                                                   VerticalAlignment="Center" Margin="0,-5,0,0"/>
                                    </Grid>

                                    <Grid Grid.Row="2">
                                        <TextBlock Text="Balance:" FontSize="14" Foreground="#8A9A92" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding BalanceText, FallbackValue='đ 2,513,000.00'}" 
                                                   FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Button Command="{Binding OpenAddDialogCommand}" 
                Width="56" Height="56" Margin="0,0,20,20" 
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="#2ED573" BorderThickness="0" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="20">
                        <TextBlock Text="+" FontSize="30" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-4,0,0"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>

    